{
    "$schema": "https://railway.app/railway.schema.json",
    "build": {
        "builder": "DOCKERFILE",
        "dockerfilePath": "Dockerfile",
        "watchPatterns": [
            "Dockerfile",
            "requirements.txt",
            "*.py",
            "google_sheets.py",
            "vision_engine.py",
            "scraper.py"
        ]
    },
    "deploy": {
        "startCommand": "python3 -m uvicorn server:app --host 0.0.0.0 --port 8000",
        "healthcheckPath": "/health",
        "healthcheckTimeout": 300,
        "restartPolicyType": "ON_FAILURE"
    }
}